---
import Layout from '../../layouts/Layout.astro'
import SanityImage from '../SanityImage.astro'
import CaseStudyCard from '../CaseStudyCard.astro'
import ContactCta from '../ContactCta.astro'
import TrustWall from '../TrustWall.astro'
import { client } from '../../lib/sanity'
import { urlFor } from '../../lib/imageUrl'
import { ALL_CASE_STUDIES_QUERY, SITE_SETTINGS_QUERY, FEATURED_BLOG_POSTS_QUERY } from '../../lib/queries'
import { useTranslations, type Lang } from '../../i18n/ui'

interface Props { lang: Lang }

const { lang } = Astro.props
const t = useTranslations(lang)
const allProjects = await client.fetch(ALL_CASE_STUDIES_QUERY)
const siteSettings = await client.fetch(SITE_SETTINGS_QUERY)
const blogPosts    = await client.fetch(FEATURED_BLOG_POSTS_QUERY)
const heroMedia: any[] = siteSettings?.heroMedia ?? []

const workUrl      = lang === 'cs' ? '/work'  : '/en/work'
const alternateUrl = lang === 'cs' ? '/en'    : '/'

const projects = allProjects.map((cs: any, i: number) => ({
  ...cs,
  title:    lang === 'en' ? (cs.titleEn   || cs.title)   : cs.title,
  tagline:  lang === 'en' ? (cs.taglineEn || cs.tagline) : cs.tagline,
  href:     `${workUrl}/${cs.slug}`,
  isLarge:  i === 0 || i === 3,
}))

// Hero chip hover náhledy (16:9). Primárně kurátorská kolekce ze Sanity
// (siteSettings.chipPreviews), fallback = cover obrázky projektů dané kategorie.
const img169 = (src: any) => urlFor(src).width(480).height(270).fit('crop').format('webp').quality(80).url()
const previewsByTag: Record<string, string[]> = {}

// 1) Kurátorská kolekce ze Sanity
for (const cp of (siteSettings?.chipPreviews ?? []) as any[]) {
  if (!cp?.category || !cp.images?.length) continue
  previewsByTag[cp.category] = cp.images.filter((im: any) => im?.asset).map(img169)
}

// 2) Fallback z coverů projektů (jen pro kategorie bez kurátorské kolekce)
for (const cs of allProjects as any[]) {
  if (!cs.coverImage) continue
  const src = img169(cs.coverImage)
  for (const svc of (cs.services ?? [])) {
    if (previewsByTag[svc]?.length) continue
    (previewsByTag[svc] ??= []).push(src)
  }
}

// ─── FAQ — jeden zdroj pravdy pro render i JSON-LD ──────────────────────────
const faqItems = lang === 'cs' ? [
  { q: 'Kolik stojí spolupráce?', a: 'Každý projekt je jiný, takže cenu vždy stanovujeme na míru. Orientačně se branding pohybuje od 80 000 Kč, webdesign od 50 000 Kč. Na prvním setkání projdeme rozsah a dostanete konkrétní nabídku.' },
  { q: 'Jak dlouho trvá projekt?', a: 'Brandingový projekt typicky trvá 6–10 týdnů, webdesign 4–8 týdnů. Záleží na rozsahu a rychlosti zpětné vazby z vaší strany. Termíny vždy nastavíme dopředu a dodržíme je.' },
  { q: 'Pracujete i s menšími firmami nebo startupy?', a: 'Ano. Pracujeme s firmami v různých fázích — od startupů, které budují brand od nuly, až po zavedené společnosti, které chtějí rebranding. Důležitý je projekt a vzájemná chemie, ne velikost firmy.' },
  { q: 'Jak probíhá spolupráce krok po kroku?', a: 'Začínáme úvodní schůzkou, kde pochopíme váš byznys a cíle. Následuje discovery fáze, návrh konceptů, prezentace a iterace na základě vaší zpětné vazby. Finální výstupy předáme v dohodnutých formátech.' },
  { q: 'Dodáváte i webové stránky, nebo jen design?', a: 'Primárně se věnujeme designu — strategii, vizuální identitě a UX/UI. U webu spolupracujeme s prověřenými vývojáři, takže zvládneme i kompletní dodávku od návrhu po spuštění.' },
  { q: 'Co potřebujete od nás na začátku?', a: 'Stačí základní brief — co děláte, pro koho, jaké máte cíle a případně příklady vizuálů, které se vám líbí. Zbytek dobereme společně na úvodní schůzce.' },
  { q: 'Můžu u vás poptat jen logo?', a: 'Jasně. Nejvíc nás baví budovat značky komplexně, ale samostatné logo uděláme rádi — i tak ale začneme krátkým briefem, ať dává smysl a vydrží roky.' },
  { q: 'Nabíráte zaměstnance nebo stážisty?', a: 'Tým rozšiřujeme spíš výjimečně, ale šikovných lidí si všímáme rádi. Pokud tě baví branding nebo UX, ozvi se nám s portfoliem — dáme vědět, až bude místo.' },
  { q: 'Jak probíhá projekt?', a: 'Začínáme úvodní schůzkou a nabídkou, pak následuje rešerše, moodboard, stylescape a finální brand manuál. Celý proces máme rozepsaný v sekci „Jak to děláme".' },
  { q: 'Registrujete ochranné známky?', a: 'Registraci sami nepodáváme, ale provedeme vás jí — pomůžeme s rešerší dostupnosti názvu i loga a propojíme vás s prověřeným patentovým zástupcem.' },
] : [
  { q: 'How much does a project cost?', a: 'Every project is unique, so we always price it individually. As a rough guide, branding starts at €3 500 and web design at €2 200. We\'ll work out an exact quote after our first meeting.' },
  { q: 'How long does a project take?', a: 'A branding project typically takes 6–10 weeks, web design 4–8 weeks. It depends on scope and how quickly you can give feedback. We always set deadlines upfront and stick to them.' },
  { q: 'Do you work with smaller companies or startups?', a: 'Yes. We work with companies at all stages — from startups building a brand from scratch to established businesses looking for a rebrand. What matters is the project and mutual fit, not company size.' },
  { q: 'How does the collaboration work?', a: 'We start with a kick-off meeting to understand your business and goals. Then comes a discovery phase, concept design, presentation and iteration based on your feedback. Final assets are delivered in agreed formats.' },
  { q: 'Do you also deliver websites, or just design?', a: 'Our core is design — strategy, visual identity and UX/UI. For websites we work with trusted developers, so we can handle the full delivery from design to launch.' },
  { q: 'What do you need from us at the start?', a: 'A basic brief is enough — what you do, who for, what your goals are and any visual references you like. We\'ll figure out the rest together at the kick-off.' },
  { q: 'Can I order just a logo?', a: 'Sure. We love building brands end-to-end, but we\'re happy to design a standalone logo too — we\'ll still start with a short brief so it makes sense and lasts.' },
  { q: 'Are you hiring or taking interns?', a: 'We grow the team only occasionally, but we always keep an eye out for talented people. If you\'re into branding or UX, send us your portfolio — we\'ll reach out when there\'s room.' },
  { q: 'How does a project work?', a: 'We start with a kick-off meeting and a quote, then research, moodboard, stylescape and the final brand manual. The whole flow is laid out in the “How we work” section.' },
  { q: 'Do you register trademarks?', a: 'We don\'t file registrations ourselves, but we\'ll guide you through it — we help check name and logo availability and connect you with a trusted trademark attorney.' },
]

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<Layout
  title={t('meta.home.title')}
  description={t('meta.home.desc')}
  {lang}
  {alternateUrl}
  extraLd={[faqLd]}
>

  <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
  <section class="hero" id="js-hero">

    <!-- Hlavní headline -->
    <div class="hero__headline-wrap container">
      <h1 class="hero__headline" id="js-headline" set:html={t('home.headline')}></h1>

      <!-- Service chips — scattered stickers -->
      <div class="hero__chips" id="js-hero-chips" aria-hidden="true">
        {([
          { label: lang === 'en' ? 'Branding'       : 'Branding',        tag: 'Branding',        icon: '<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>', style: 'top: 0%;  left: 30%; rotate: -3deg;',  solid: true  },
          { label: lang === 'en' ? 'Naming'         : 'Naming',           tag: 'Naming',          icon: '<polyline points="4 7 4 4 20 4 20 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="9" y1="20" x2="15" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="12" y1="4" x2="12" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',  style: 'top: 6%;  left: 62%; rotate: 4deg;',  solid: false },
          { label: lang === 'en' ? 'Web design'     : 'Webdesign',        tag: 'Webdesign',       icon: '<rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',  style: 'top: 36%; left: 2%;  rotate: -4deg;', solid: false },
          { label: lang === 'en' ? 'Motion design'  : 'Animace',          tag: 'Animace',         icon: '<polygon points="5 3 19 12 5 21 5 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>', style: 'top: 40%; left: 55%; rotate: 3deg;',  solid: true  },
          { label: lang === 'en' ? 'Packaging'      : 'Obalový design',   tag: 'Obalový design',  icon: '<path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" stroke="currentColor" stroke-width="1.5"/>', style: 'top: 72%; left: 4%;  rotate: 5deg;',  solid: true  },
          { label: lang === 'en' ? 'Graphic design' : 'Grafický design',  tag: 'Grafický design', icon: '<path d="M12 19l7-7 3 3-7 7-3-3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="6.5" cy="6.5" r="1.5" fill="currentColor"/>', style: 'top: 70%; left: 48%; rotate: -3deg;', solid: false },
        ] as const).map(chip => {
          const topPct = parseFloat(chip.style.match(/top:\s*([\d.]+)%/)?.[1] ?? '0')
          const pbelow = topPct < 48
          return (
          <a
            href={`${workUrl}?tag=${encodeURIComponent(chip.tag)}`}
            class={`hero__chip${chip.solid ? ' hero__chip--solid' : ''}${pbelow ? ' hero__chip--pbelow' : ''}`}
            style={chip.style}
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" set:html={chip.icon} />
            {chip.label}
            {previewsByTag[chip.tag]?.length ? (
              <span class="hero__chip-preview" aria-hidden="true">
                {previewsByTag[chip.tag].slice(0, 6).map((src) => (
                  <img class="hero__chip-preview-img" src={src} alt="" loading="lazy" decoding="async" />
                ))}
              </span>
            ) : null}
          </a>
          )
        })}
      </div>
    </div>

    <!-- Custom cursor -->
  <div class="hero__cursor" id="js-hero-cursor" aria-hidden="true">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
      <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>

  <!-- Video kontejner — clip-path se rozevře při scrollu -->
    <a href={workUrl} class="hero__reel-wrap" id="js-reel-wrap" aria-label={lang === 'cs' ? 'Zobrazit práce' : 'View work'}>
      <div class="hero__reel" id="js-reel">
        {heroMedia.length > 0 ? heroMedia.map((slide: any, i: number) => (
          <div class={`hero__slide${i === 0 ? ' is-active' : ''}`} data-index={i} data-type={slide._type}>
            {slide._type === 'heroVideo'
              ? <video src={slide.url} autoplay muted playsinline class="hero__media" />
              : slide._type === 'heroExternalImage'
              ? <img src={slide.url} alt={slide.alt ?? ''} class="hero__media" loading={i === 0 ? 'eager' : 'lazy'} />
              : <SanityImage
                  image={slide.image}
                  alt={slide.alt ?? ''}
                  width={1920}
                  height={1080}
                  widths={[800, 1280, 1920]}
                  sizes="100vw"
                  class="hero__media"
                />
            }
          </div>
        )) : (
          <div class="hero__slide is-active" data-type="heroVideo">
            <video autoplay loop muted playsinline class="hero__media">
              <source src="https://videos.pexels.com/video-files/3571264/3571264-uhd_2560_1440_30fps.mp4" type="video/mp4" />
            </video>
          </div>
        )}
        <div class="hero__reel-overlay"></div>
      </div>
    </a>

    <!-- Spodní desc + CTA -->
    <div class="hero__bot container" id="js-hero-bot">
      <p class="hero__desc">{t('home.desc')}</p>
      <a href={workUrl} class="hero__cta btn-secondary">
        {t('home.cta')}
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
          <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </section>

  <TrustWall logos={siteSettings?.clientLogos ?? []} {lang} />

  <!-- ─── Work grid ─────────────────────────────────────────────────────── -->
  {allProjects?.length > 0 && (
    <section class="projects" id="js-projects">
      <div class="container">
        <div class="projects__header">
          <h2 class="section-heading">{t('home.selected')}</h2>
          <a href={workUrl} class="projects__all btn-secondary">{t('work.viewAll')}</a>
        </div>
      </div>

      <div class="container">
      <div class="projects__list">
        {projects.map((cs: any) => (
          <CaseStudyCard
            title={cs.title}
            slug={cs.slug}
            tagline={cs.tagline}
            services={cs.services}
            coverImage={cs.coverImage}
            cardVideo={cs.cardVideo}
            variant={cs.isLarge ? 'wide' : 'home'}
            headingLevel={3}
            {lang}
          />
        ))}
      </div>

      <div class="projects__footer">
        <a href={workUrl} class="projects__cta btn-secondary">
          {lang === 'cs' ? 'Všechny projekty' : 'All projects'}
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
            <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      </div>
    </section>
  )}

  <!-- ─── Services ───────────────────────────────────────────────────────── -->
  <section class="services container" id="js-services">
    <h2 class="services__heading section-heading">{lang === 'cs' ? 'Co děláme' : 'What we do'}</h2>
    <div class="services__grid">
      {([
        { cs: 'Branding',        en: 'Branding',        tag: 'Branding',        desc_cs: 'Budujeme značky s jasnou osobností — od strategie a pojmenování po vizuální identitu a brand manuál.', desc_en: 'We build brands with clear personality — from strategy and naming to visual identity and brand guidelines.' },
        { cs: 'Webdesign',       en: 'Web design',      tag: 'Webdesign',       desc_cs: 'Navrhujeme weby, které prodávají. UX výzkum, prototypy, finální design a předání developerům.', desc_en: 'We design websites that convert. UX research, prototypes, final design and developer handoff.' },
        { cs: 'Obalový design',  en: 'Packaging',       tag: 'Obalový design',  desc_cs: 'Obal je první dotek zákazníka se značkou. Navrhujeme packaging, který na regále nepřehlédnete.', desc_en: 'Packaging is the first touchpoint. We design packaging that stands out on the shelf.' },
        { cs: 'Grafický design', en: 'Graphic design',  tag: 'Grafický design', desc_cs: 'Tiskové materiály, infografiky, prezentace a veškerý grafický obsah konzistentní s vaší značkou.', desc_en: 'Print materials, infographics, presentations and all visual content consistent with your brand.' },
        { cs: 'Animace',         en: 'Motion design',   tag: 'Animace',         desc_cs: 'Pohyb dává značkám život. Vytváříme animace pro sociální sítě, pitch decky i produktová videa.', desc_en: 'Motion gives brands life. We create animations for social media, pitch decks and product videos.' },
        { cs: 'Naming',          en: 'Naming',          tag: 'Naming',          desc_cs: 'Jméno je základní kámen značky. Pomáháme najít název, který rezonuje, je zapamatovatelný a dostupný.', desc_en: 'A name is the cornerstone of a brand. We help find a name that resonates, is memorable and available.' },
      ] as const).map(s => (
        <div class="service-item">
          <a
            href={`${workUrl}?tag=${encodeURIComponent(s.tag)}`}
            class="project-item__tag service-item__tag"
          >{lang === 'en' ? s.en : s.cs}</a>
          <p class="service-item__desc">{lang === 'en' ? s.desc_en : s.desc_cs}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── Process ────────────────────────────────────────────────────── -->
  {(siteSettings?.processSteps?.length > 0) && (() => {
    const steps: any[] = siteSettings.processSteps
    return (
      <section class="process" id="js-process">
        <div class="process__label container">
          <h2 class="section-heading">{lang === 'cs' ? 'Jak to děláme' : 'How we work'}</h2>
        </div>
        <div class="process__list">
          {steps.map((step: any, i: number) => {
            const title = lang === 'en' ? (step.titleEn || step.title) : step.title
            const desc  = lang === 'en' ? (step.descriptionEn || step.description) : step.description
            const num   = String(i + 1).padStart(2, '0')
            return (
              <div class="process__row container" data-process-row>
                <span class="process__num" aria-hidden="true">{num}</span>
                <div class="process__content">
                  <h3 class="process__title">{title}</h3>
                  <p class="process__desc">{desc}</p>
                </div>
              </div>
            )
          })}
        </div>
      </section>
    )
  })()}

  <!-- ─── Blog ────────────────────────────────────────────────────────── -->
  {blogPosts?.length > 0 && (
    <section class="blog-section" id="js-blog">
      <div class="blog-section__head container">
        <h2 class="section-heading">{lang === 'cs' ? 'Ze studia' : 'From the studio'}</h2>
      </div>

      <div class="blog-scroll" id="js-blog-scroll">
        <div class="blog-track">
          {blogPosts.map((post: any) => {
            const title = lang === 'en' ? (post.titleEn || post.title) : post.title
            const href  = lang === 'cs' ? `/blog/${post.slug}` : `/en/blog/${post.slug}`
            const date  = post.publishedAt
              ? new Date(post.publishedAt).toLocaleDateString(lang === 'cs' ? 'cs-CZ' : 'en-GB', { day: 'numeric', month: 'numeric', year: 'numeric' })
              : ''
            return (
              <a href={href} class="blog-card">
                <div class="blog-card__image">
                  {post.coverImage
                    ? <SanityImage image={post.coverImage} alt={post.coverImage?.alt ?? title} width={600} height={750} widths={[400, 600]} sizes="30vw" />
                    : <div class="blog-card__placeholder" />
                  }
                </div>
                <div class="blog-card__body">
                  {post.category && (
                    <div class="blog-card__tags">
                      <span class="blog-card__tag">{post.category}</span>
                    </div>
                  )}
                  {date && <time class="blog-card__date">{date}</time>}
                  <h3 class="blog-card__title">{title}</h3>
                </div>
              </a>
            )
          })}
        </div>
      </div>

      <div class="blog-section__footer container">
        <a href={lang === 'cs' ? '/blog' : '/en/blog'} class="blog-section__btn btn-secondary">
          {lang === 'cs' ? 'Všechny články' : 'All articles'}
        </a>
        <div class="blog-section__arrows">
          <button id="js-blog-prev" class="blog-arrow" aria-label="Předchozí">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
              <path d="M16 10H4M8 14l-4-4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button id="js-blog-next" class="blog-arrow" aria-label="Další">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
              <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
    </section>
  )}

  <!-- ─── FAQ ─────────────────────────────────────────────────────────── -->
  <section class="faq container" id="js-faq">
    <div class="faq__header">
      <span class="faq__label">{lang === 'cs' ? 'Časté dotazy' : 'FAQ'}</span>
      <h2 class="faq__title section-heading">{lang === 'cs' ? 'Co vás zajímá?' : 'Your questions, answered'}</h2>
    </div>

    <div class="faq__list" id="js-faq-list">
      {faqItems.map((item, i) => (
        <div class="faq__item" data-faq-item>
          <button class="faq__question" aria-expanded="false" data-faq-btn>
            <span class="faq__q-text">{item.q}</span>
            <span class="faq__icon" aria-hidden="true">
              <span class="faq__icon-bar faq__icon-bar--h"></span>
              <span class="faq__icon-bar faq__icon-bar--v"></span>
            </span>
          </button>
          <div class="faq__answer" data-faq-answer>
            <p class="faq__answer-text">{item.a}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── CTA ──────────────────────────────────────────────────────────── -->
  <ContactCta {lang} id="contact" />

</Layout>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import { SplitText } from 'gsap/SplitText'

  gsap.registerPlugin(ScrollTrigger, SplitText)

  // ── Headline SplitText intro ──────────────────────────────────────────
  const headline = document.getElementById('js-headline')
  if (headline) {
    const split = new SplitText(headline, { type: 'words' })
    gsap.from(split.words, {
      y: 100, opacity: 0, duration: 1.2,
      stagger: 0.06, ease: 'power4.out', delay: 0.2,
    })
  }

  // ── Hero custom cursor ────────────────────────────────────────────────
  const heroCursor = document.getElementById('js-hero-cursor')
  const reelTrigger = document.getElementById('js-reel-wrap')
  const heroSection = document.getElementById('js-hero')

  if (heroCursor && reelTrigger && heroSection && !window.matchMedia('(hover: none)').matches) {
    const moveX = gsap.quickTo(heroCursor, 'x', { duration: 0.5, ease: 'power3.out' })
    const moveY = gsap.quickTo(heroCursor, 'y', { duration: 0.5, ease: 'power3.out' })

    // Track mouse globally inside hero so cursor position stays correct
    heroSection.addEventListener('mousemove', (e) => {
      const rect = heroSection.getBoundingClientRect()
      moveX(e.clientX - rect.left)
      moveY(e.clientY - rect.top)
    })

    // Show/hide only when over the reel area
    reelTrigger.addEventListener('mouseenter', () => {
      gsap.to(heroCursor, { scale: 1, opacity: 1, duration: 0.3, ease: 'power2.out' })
    })
    reelTrigger.addEventListener('mouseleave', () => {
      gsap.to(heroCursor, { scale: 0, opacity: 0, duration: 0.2, ease: 'power2.in' })
    })
  }

  // ── Hero chips entrance ───────────────────────────────────────────────
  const chips = document.querySelectorAll<HTMLElement>('.hero__chip')
  if (chips.length) {
    gsap.from(chips, {
      opacity: 0,
      scale: 0.6,
      y: (i) => [30, -20, 25, -30, 20, -15][i] ?? 20,
      x: (i) => [20, -15, 30, -20, 15, -25][i] ?? 15,
      duration: 0.7,
      ease: 'back.out(1.8)',
      stagger: { amount: 0.5, from: 'random' },
      delay: 1.0,
      onComplete: () => {
        // Jemné, pomalé plování nahoru a dolů (každý chip trochu jinak)
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return
        chips.forEach((chip, i) => {
          gsap.to(chip, {
            y: -10 - (i % 3) * 3,
            duration: 2.6 + (i % 4) * 0.6,
            ease: 'sine.inOut',
            repeat: -1,
            yoyo: true,
            delay: i * 0.18,
          })
        })
      },
    })

    // Hover náhled — karty se skládají na sebe (deck), desktop only
    if (window.matchMedia('(min-width: 64.0625em)').matches) {
      chips.forEach((chip) => {
        const imgs = Array.from(chip.querySelectorAll<HTMLImageElement>('.hero__chip-preview-img'))
        if (!imgs.length) return
        // Stabilní klidová poloha každé karty → pootočená hromádka
        const rest = imgs.map((_, i) => ({
          rotate: ((i * 37) % 11) - 5,
          x: ((i * 23) % 9) - 4,
          y: ((i * 17) % 7) - 3,
        }))
        let idx = 0, topZ = 0, timer: number | undefined

        const drop = () => {
          const im = imgs[idx]
          const r = rest[idx]
          im.style.zIndex = String(++topZ)
          gsap.fromTo(im,
            { opacity: 0, x: r.x, y: r.y - 28, rotate: r.rotate - 8, scale: 1.06 },
            { opacity: 1, x: r.x, y: r.y, rotate: r.rotate, scale: 1, duration: 0.45, ease: 'power3.out' }
          )
          idx = (idx + 1) % imgs.length
        }

        chip.addEventListener('mouseenter', () => {
          gsap.killTweensOf(imgs)
          gsap.set(imgs, { opacity: 0 })
          idx = 0; topZ = 0
          drop()                                   // první karta hned
          if (imgs.length > 1) timer = window.setInterval(drop, 520)
        })
        chip.addEventListener('mouseleave', () => {
          if (timer) clearInterval(timer)
          gsap.killTweensOf(imgs)
          gsap.to(imgs, { opacity: 0, duration: 0.2 })
        })
      })
    }

  }

gsap.from('#js-hero-bot', {
    y: 20, opacity: 0, duration: 0.8, ease: 'power3.out', delay: 0.8,
  })

  // ── Hero slideshow — hard cut, video on ended, images 1s ─────────────
  const heroSlides = document.querySelectorAll<HTMLElement>('.hero__slide')
  if (heroSlides.length > 1) {
    let current = 0

    function next() {
      heroSlides[current].classList.remove('is-active')
      current = (current + 1) % heroSlides.length
      heroSlides[current].classList.add('is-active')
      scheduleNext()
    }

    function scheduleNext() {
      const slide = heroSlides[current]
      const type = slide.dataset.type
      if (type === 'heroVideo') {
        const video = slide.querySelector('video')
        if (video) {
          video.currentTime = 0
          video.play()
          video.addEventListener('ended', next, { once: true })
        } else {
          setTimeout(next, 3000)
        }
      } else {
        setTimeout(next, 1000)
      }
    }

    scheduleNext()
  }

  // ── Reel entrance + scroll expand ─────────────────────────────────────
  const reelWrap = document.getElementById('js-reel-wrap')
  const reel     = document.getElementById('js-reel')

  if (reelWrap && reel) {
    const isMobile = window.matchMedia('(max-width: 48em)').matches

    if (isMobile) {
      // Mobil: jen scale entrance, žádný pin
      gsap.set(reelWrap, { scale: 0.9, transformOrigin: '50% 50%' })
      gsap.to(reelWrap, { scale: 1, duration: 1.4, ease: 'power4.out', delay: 0.4 })
    } else {
      // Desktop: scale entrance, pak pin + clip-path scroll expand
      gsap.set(reelWrap, { scale: 0.9, transformOrigin: '50% 50%' })
      gsap.set(reel, { clipPath: 'inset(4% 10% 4% 10% round 16px)' })

      // Entrance: scale 0.9 → 1
      gsap.to(reelWrap, { scale: 1, duration: 1.4, ease: 'power4.out', delay: 0.4 })

      // Scroll: clip-path se rozevře na celou plochu
      ScrollTrigger.create({
        trigger: reelWrap,
        start: 'top top',
        end: '+=120%',
        pin: true,
        pinSpacing: true,
        scrub: 1,
        onUpdate: (self) => {
          const p = self.progress
          const v = gsap.utils.interpolate(4, 0, p)
          const h = gsap.utils.interpolate(10, 0, p)
          const r = gsap.utils.interpolate(16, 0, p)
          gsap.set(reel, {
            clipPath: `inset(${v}% ${h}% ${v}% ${h}% round ${r}px)`,
          })
        },
      })
    }
  }

  // Project cards: reveal via global [data-fade]; hover-play handled in CaseStudyCard

  // ── Blog drag scroll ─────────────────────────────────────────────────
  const blogScroll = document.getElementById('js-blog-scroll')
  if (blogScroll) {
    let isDown = false, startX = 0, scrollLeft = 0
    blogScroll.addEventListener('mousedown', e => { isDown = true; startX = e.pageX - blogScroll.offsetLeft; scrollLeft = blogScroll.scrollLeft })
    blogScroll.addEventListener('mouseleave', () => { isDown = false })
    blogScroll.addEventListener('mouseup', () => { isDown = false })
    blogScroll.addEventListener('mousemove', e => {
      if (!isDown) return
      e.preventDefault()
      const x = e.pageX - blogScroll.offsetLeft
      blogScroll.scrollLeft = scrollLeft - (x - startX) * 1.2
    })

    // ── Blog arrow navigation ───────────────────────────────────────────
    const firstCard = blogScroll.querySelector<HTMLElement>('.blog-card')
    const cardWidth = firstCard ? firstCard.offsetWidth + 24 : 300 // 24px gap
    document.getElementById('js-blog-prev')?.addEventListener('click', () => {
      blogScroll.scrollBy({ left: -cardWidth, behavior: 'smooth' })
    })
    document.getElementById('js-blog-next')?.addEventListener('click', () => {
      blogScroll.scrollBy({ left: cardWidth, behavior: 'smooth' })
    })
  }

  // ── Process rows ─────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-process-row]').forEach((row) => {
    const num     = row.querySelector('.process__num')
    const title   = row.querySelector('.process__title')
    const desc    = row.querySelector('.process__desc')

    const tl = gsap.timeline({
      scrollTrigger: { trigger: row, start: 'top 80%', toggleActions: 'play none none none' }
    })

    tl.fromTo(num,   { x: -30, opacity: 0 }, { x: 0, opacity: 1, duration: 1,   ease: 'power4.out' }, 0)
      .fromTo(title, { y: 28,  opacity: 0, clipPath: 'inset(0 0 100% 0)' },
                     { y: 0,   opacity: 1, clipPath: 'inset(0 0 0% 0)',   duration: 0.8, ease: 'power3.out' }, 0.15)
      .fromTo(desc,  { y: 16,  opacity: 0 }, { y: 0,  opacity: 1, duration: 0.7, ease: 'power3.out' }, 0.35)

    // Tint the number accent only while the row sits in the viewport centre
    ScrollTrigger.create({
      trigger: row,
      start: 'top 75%',
      end: 'bottom 25%',
      onToggle: self => num?.classList.toggle('is-active', self.isActive),
    })
  })

  // ── Services stagger ─────────────────────────────────────────────────
  const serviceItems = document.querySelectorAll('.service-item')
  if (serviceItems.length) {
    gsap.from('.services__heading', {
      y: 30, opacity: 0, duration: 0.8, ease: 'power3.out',
      scrollTrigger: { trigger: '.services', start: 'top 85%' },
    })
    gsap.from(serviceItems, {
      y: 40, opacity: 0, duration: 0.7, ease: 'power3.out',
      stagger: { amount: 0.5, from: 'start' },
      scrollTrigger: { trigger: '.services__grid', start: 'top 85%' },
    })
  }

  // ── FAQ accordion ─────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-faq-item]').forEach((item) => {
    const btn    = item.querySelector<HTMLElement>('[data-faq-btn]')!
    const answer = item.querySelector<HTMLElement>('[data-faq-answer]')!
    const icon   = btn.querySelector<SVGPathElement>('svg path:last-child')

    // Set initial height to 0
    gsap.set(answer, { height: 0, overflow: 'hidden' })

    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true'

      // Close all others
      document.querySelectorAll<HTMLElement>('[data-faq-item]').forEach((other) => {
        if (other === item) return
        const ob  = other.querySelector<HTMLElement>('[data-faq-btn]')!
        const oa  = other.querySelector<HTMLElement>('[data-faq-answer]')!
        ob.setAttribute('aria-expanded', 'false')
        other.classList.remove('is-open')
        gsap.to(oa, { height: 0, duration: 0.35, ease: 'power3.inOut' })
      })

      // Toggle current
      if (isOpen) {
        btn.setAttribute('aria-expanded', 'false')
        item.classList.remove('is-open')
        gsap.to(answer, { height: 0, duration: 0.35, ease: 'power3.inOut' })
      } else {
        btn.setAttribute('aria-expanded', 'true')
        item.classList.add('is-open')
        gsap.to(answer, { height: 'auto', duration: 0.45, ease: 'power3.inOut' })
      }
    })
  })

  // FAQ scroll entrance
  gsap.from('[data-faq-item]', {
    y: 30, opacity: 0, duration: 0.6, ease: 'power3.out',
    stagger: 0.07,
    scrollTrigger: { trigger: '#js-faq', start: 'top 80%' },
  })
</script>

