---
import Layout from '../../layouts/Layout.astro'
import PortableText from '../PortableText.astro'
import SanityImage from '../SanityImage.astro'
import ContactCta from '../ContactCta.astro'
import { urlFor } from '../../lib/imageUrl'
import { useTranslations, type Lang } from '../../i18n/ui'

interface Props {
  lang: Lang
  slug: string
  cs: any
  allNav?: { slug: string; title: string; titleEn: string }[]
}

const { lang, slug, cs, allNav = [] } = Astro.props

// Hero video — z Sanity
const heroVideo = cs?.heroVideo || null

// Brief / Výsledek — z Sanity (s EN fallbackem na CS)
const brief  = lang === 'en' ? (cs?.briefEn    || cs?.brief)    : cs?.brief
const result = lang === 'en' ? (cs?.vysledekEn || cs?.vysledek) : cs?.vysledek

// Gallery — z Sanity: každá položka je obrázek nebo video
const galleryItems = (cs?.gallery ?? []).map((g: any) => {
  const thumb = g.image ? urlFor(g.image).width(900).fit('max').format('webp').quality(82).url() : undefined
  const full  = g.image ? urlFor(g.image).width(1600).fit('max').format('webp').quality(85).url() : undefined
  return g.videoUrl
    ? { type: 'video', src: g.videoUrl, thumb, alt: g.alt ?? '' }
    : { type: 'image', src: full, thumb, alt: g.alt ?? '' }
}).filter((g: any) => g.src || g.thumb)

// Prev / next
const navIdx  = allNav.findIndex(p => p.slug === slug)
const prevCs  = navIdx > 0 ? allNav[navIdx - 1] : null
const nextCs  = navIdx < allNav.length - 1 ? allNav[navIdx + 1] : null
const prevTitle = prevCs ? (lang === 'en' ? (prevCs.titleEn || prevCs.title) : prevCs.title) : null
const nextTitle = nextCs ? (lang === 'en' ? (nextCs.titleEn || nextCs.title) : nextCs.title) : null
const t = useTranslations(lang)

const title    = lang === 'en' ? (cs?.titleEn    || cs?.title)   : cs?.title
const tagline  = lang === 'en' ? (cs?.taglineEn  || cs?.tagline) : cs?.tagline
const seoDesc  = lang === 'en' ? (cs?.seoDescriptionEn || cs?.seoDescription || tagline) : (cs?.seoDescription || tagline)
const credits  = lang === 'en' ? (cs?.creditsEn  || cs?.credits) : cs?.credits

const workUrl      = lang === 'cs' ? '/work'          : '/en/work'
const alternateUrl = lang === 'cs' ? `/en/work/${slug}` : `/work/${slug}`
const homeUrl   = lang === 'cs' ? '/' : '/en'
const homeLabel = lang === 'cs' ? 'Domů' : 'Home'
const workLabel = lang === 'cs' ? 'Práce' : 'Work'

const ogImageUrl = cs?.coverImage
  ? urlFor(cs.coverImage).width(1200).height(630).fit('crop').format('webp').url()
  : undefined

const baseUrl = 'https://slant.cz'
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: homeLabel, item: `${baseUrl}${homeUrl}` },
    { '@type': 'ListItem', position: 2, name: workLabel, item: `${baseUrl}${workUrl}` },
    { '@type': 'ListItem', position: 3, name: title, item: `${baseUrl}${workUrl}/${slug}` },
  ],
}

const caseStudyLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: title,
  description: seoDesc,
  creator: { '@type': 'Organization', name: 'Slant s.r.o.', url: baseUrl },
  ...(cs?.year && { dateCreated: String(cs.year) }),
  ...(ogImageUrl && { image: ogImageUrl }),
  ...(cs?.services?.length && { keywords: cs.services.join(', ') }),
}
---

<Layout
  title={title ?? '404'}
  description={seoDesc}
  ogImage={ogImageUrl}
  extraLd={[breadcrumb, caseStudyLd]}
  {lang}
  {alternateUrl}
>
  {!cs ? (
    <div class="container" style="padding-block: var(--sp-3xl); color: var(--clr-muted)">
      {t('work.notFound')}
    </div>
  ) : (
    <article class="cs" data-sanity-document={cs._id}>
      <!-- Hero media with breadcrumb overlaid top-left -->
      <div class="cs-media-wrap container" data-fade>
        <div class="cs-media">
          {heroVideo ? (
            <video src={heroVideo} autoplay loop muted playsinline class="cs-media__video" />
          ) : cs.coverImage ? (
            <SanityImage
              image={cs.coverImage}
              alt={cs.coverImage.alt ?? title}
              width={1800}
              height={1012}
              widths={[800, 1200, 1800]}
              sizes="100vw"
              quality={90}
              loading="eager"
              class="cs-media__image"
            />
          ) : null}
          <nav class="breadcrumbs cs-breadcrumbs" aria-label="Breadcrumb">
            <a href={homeUrl}>{homeLabel}</a>
            <a href={workUrl}>{workLabel}</a>
          </nav>
        </div>
      </div>

      <!-- Intro block -->
      <header class="cs-intro container">
        <div class="cs-intro__top" data-fade>
          <h1
            class="cs-intro__title text-display"
            data-sanity={lang === 'en' ? 'titleEn' : 'title'}
          >{title}</h1>
          {cs.client && <span class="cs-intro__client">{cs.client}</span>}
        </div>

        <hr class="cs-intro__divider" data-fade />

        <dl class="cs-intro__meta" data-fade>
          {cs.year     && <div class="cs-intro__meta-item"><dt>{t('cs.year')}</dt><dd>{cs.year}</dd></div>}
          {cs.client   && <div class="cs-intro__meta-item"><dt>{t('cs.client')}</dt><dd>{cs.client}</dd></div>}
          {cs.industry && <div class="cs-intro__meta-item"><dt>{t('cs.industry')}</dt><dd>{cs.industry}</dd></div>}
          {cs.liveUrl  && (
            <div class="cs-intro__meta-item">
              <dt>{t('cs.live')}</dt>
              <dd><a href={cs.liveUrl} target="_blank" rel="noopener" class="cs-intro__live">{t('work.viewSite')}</a></dd>
            </div>
          )}
        </dl>

        {(cs.services?.length > 0 || brief || result || tagline) && (
          <div class="cs-intro__detail" data-fade>
            {cs.services?.length > 0 && (
              <div class="cs-intro__col cs-intro__col--services">
                <span class="cs-intro__label">{lang === 'cs' ? 'Služby' : 'Services'}</span>
                <ul class="cs-intro__tags">
                  {cs.services.map((s: string) => (
                    <li>
                      <a class="cs-intro__tag" href={`${workUrl}?tag=${encodeURIComponent(s)}`}>{s}</a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {(brief || result) ? (
              <>
                {brief && (
                  <div class="cs-intro__col cs-intro__col--text">
                    <span class="cs-intro__label">Brief</span>
                    <p class="cs-intro__lead">{brief}</p>
                  </div>
                )}
                {result && (
                  <div class="cs-intro__col cs-intro__col--text">
                    <span class="cs-intro__label">{lang === 'cs' ? 'Výsledek' : 'Result'}</span>
                    <p class="cs-intro__lead">{result}</p>
                  </div>
                )}
              </>
            ) : tagline ? (
              <div class="cs-intro__col cs-intro__col--text">
                <span class="cs-intro__label">{lang === 'cs' ? 'O projektu' : 'About'}</span>
                <p class="cs-intro__lead" data-sanity={lang === 'en' ? 'taglineEn' : 'tagline'}>{tagline}</p>
              </div>
            ) : null}
          </div>
        )}
      </header>

      {galleryItems.length > 0 && (
        <section class="cs-gallery container" data-fade>
          <div class="cs-gallery__grid">
            {galleryItems.map((item, i) => (
              <button class="cs-gallery__item" type="button" data-lightbox-index={i} aria-label={lang === 'cs' ? 'Zvětšit' : 'Open'}>
                {item.type === 'video' ? (
                  <video class="cs-gallery__media" src={item.src} poster={item.thumb} autoplay loop muted playsinline preload="metadata"></video>
                ) : (
                  <img class="cs-gallery__media" src={item.thumb} alt={item.alt} loading="lazy" />
                )}
                <span class="cs-gallery__zoom" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3M11 8v6M8 11h6"/>
                  </svg>
                </span>
              </button>
            ))}
          </div>
        </section>
      )}

      {cs.sections?.length > 0 && (
        <div class="cs-sections container">
          {cs.sections.map((section: any) => {
            const heading = lang === 'en' ? (section.headingEn || section.heading) : section.heading
            const body    = lang === 'en' && section.bodyEn?.length ? section.bodyEn : section.body
            return (
              <section class="cs-section">
                {heading && <h2 class="cs-section__heading" data-fade>{heading}</h2>}
                {body?.length > 0 && (
                  <div class="cs-section__body" data-fade>
                    <PortableText blocks={body} />
                  </div>
                )}
                {section.images?.length > 0 && (
                  <div class="cs-section__images" data-count={section.images.length} data-fade>
                    {section.images.map((img: any) => {
                      const single = section.images.length === 1
                      return (
                        <figure class="cs-section__figure">
                          <SanityImage
                            image={img}
                            alt={img.alt ?? ''}
                            width={single ? 1800 : 1000}
                            height={single ? 1013 : 667}
                            widths={single ? [800, 1200, 1800] : [400, 700, 1000]}
                            sizes={single ? '100vw' : '(max-width: 768px) 100vw, 50vw'}
                            quality={88}
                            class="cs-section__img"
                          />
                          {img.caption && <figcaption class="cs-section__caption text-small">{img.caption}</figcaption>}
                        </figure>
                      )
                    })}
                  </div>
                )}
              </section>
            )
          })}
        </div>
      )}

      {credits && (
        <footer class="cs-credits container" data-fade>
          <p class="text-small" style="color: var(--clr-muted)">{credits}</p>
        </footer>
      )}

      <!-- ─── CTA ─────────────────────────────────────────────────────── -->
      <ContactCta {lang} />

      <!-- ─── Case study nav ─────────────────────────────────────────── -->
      <nav class="cs-nav container" aria-label="Další projekty">

        {prevCs ? (
          <a href={`${workUrl}/${prevCs.slug}`} class="cs-nav__item cs-nav__item--prev">
            {prevCs.coverImage && (
              <div class="cs-nav__thumb">
                <SanityImage image={prevCs.coverImage} alt={prevTitle ?? ''} width={320} height={200} widths={[320]} sizes="160px" class="cs-nav__thumb-img" />
              </div>
            )}
            <div class="cs-nav__text">
              <span class="cs-nav__label">
                <svg width="14" height="14" viewBox="0 0 20 20" fill="none">
                  <path d="M16 10H4M8 14l-4-4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {lang === 'cs' ? 'Předchozí' : 'Previous'}
              </span>
              <span class="cs-nav__title">{prevTitle}</span>
            </div>
          </a>
        ) : <span />}

        <a href={workUrl} class="cs-nav__grid" aria-label={lang === 'cs' ? 'Všechny projekty' : 'All projects'}>
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
            <rect x="2" y="2" width="6" height="6" rx="1" fill="currentColor"/>
            <rect x="12" y="2" width="6" height="6" rx="1" fill="currentColor"/>
            <rect x="2" y="12" width="6" height="6" rx="1" fill="currentColor"/>
            <rect x="12" y="12" width="6" height="6" rx="1" fill="currentColor"/>
          </svg>
        </a>

        {nextCs ? (
          <a href={`${workUrl}/${nextCs.slug}`} class="cs-nav__item cs-nav__item--next">
            <div class="cs-nav__text cs-nav__text--right">
              <span class="cs-nav__label">
                {lang === 'cs' ? 'Další' : 'Next'}
                <svg width="14" height="14" viewBox="0 0 20 20" fill="none">
                  <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="cs-nav__title">{nextTitle}</span>
            </div>
            {nextCs.coverImage && (
              <div class="cs-nav__thumb">
                <SanityImage image={nextCs.coverImage} alt={nextTitle ?? ''} width={320} height={200} widths={[320]} sizes="160px" class="cs-nav__thumb-img" />
              </div>
            )}
          </a>
        ) : <span />}

      </nav>

      {galleryItems.length > 0 && (
        <div id="cs-lightbox" class="cs-lightbox" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-label="Galerie">
          <button class="cs-lightbox__close" type="button" aria-label={lang === 'cs' ? 'Zavřít' : 'Close'}>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
          <button class="cs-lightbox__nav cs-lightbox__nav--prev" type="button" aria-label={lang === 'cs' ? 'Předchozí' : 'Previous'}>
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <div class="cs-lightbox__stage" id="cs-lightbox-stage"></div>
          <button class="cs-lightbox__nav cs-lightbox__nav--next" type="button" aria-label={lang === 'cs' ? 'Další' : 'Next'}>
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>

        <script define:vars={{ galleryItems }}>
          ;(function () {
            const lb    = document.getElementById('cs-lightbox')
            const stage = document.getElementById('cs-lightbox-stage')
            if (!lb || !stage) return
            const items = galleryItems
            let idx = 0

            function render() {
              const it = items[idx]
              stage.innerHTML = ''
              let el
              if (it.type === 'video') {
                el = document.createElement('video')
                el.src = it.src
                el.controls = true
                el.autoplay = true
                el.loop = true
                el.playsInline = true
              } else {
                el = document.createElement('img')
                el.src = it.src
                el.alt = it.alt || ''
              }
              el.className = 'cs-lightbox__media'
              stage.appendChild(el)
            }
            function open(i) {
              idx = (i + items.length) % items.length
              render()
              lb.removeAttribute('hidden')
              lb.setAttribute('aria-hidden', 'false')
              document.body.style.overflow = 'hidden'
              requestAnimationFrame(() => lb.classList.add('is-open'))
            }
            function close() {
              lb.classList.remove('is-open')
              document.body.style.overflow = ''
              lb.setAttribute('aria-hidden', 'true')
              setTimeout(() => { lb.setAttribute('hidden', ''); stage.innerHTML = '' }, 250)
            }
            function go(dir) { idx = (idx + dir + items.length) % items.length; render() }

            document.querySelectorAll('[data-lightbox-index]').forEach(btn => {
              btn.addEventListener('click', () => open(Number(btn.dataset.lightboxIndex)))
            })
            lb.querySelector('.cs-lightbox__close').addEventListener('click', close)
            lb.querySelector('.cs-lightbox__nav--prev').addEventListener('click', () => go(-1))
            lb.querySelector('.cs-lightbox__nav--next').addEventListener('click', () => go(1))
            // Click on backdrop (outside the media/buttons) closes
            lb.addEventListener('click', (e) => { if (e.target === lb || e.target === stage) close() })
            // Keyboard
            document.addEventListener('keydown', (e) => {
              if (lb.hasAttribute('hidden')) return
              if (e.key === 'Escape') close()
              else if (e.key === 'ArrowLeft') go(-1)
              else if (e.key === 'ArrowRight') go(1)
            })
          })()
        </script>
      )}
    </article>
  )}
</Layout>

<style>
/* ── Hero media ──────────────────────────────────────────────────────── */
.cs-media-wrap { padding-block-start: var(--sp-md); }
.cs-media {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  max-height: 600px;
  overflow: hidden;
  border-radius: var(--radius-lg);
  background: var(--clr-surface);
}

/* Breadcrumb overlaid on the media (top-left), frosted for legibility */
.cs-media .cs-breadcrumbs {
  position: absolute;
  top: var(--sp-md);
  left: var(--sp-md);
  margin: 0;
  z-index: 2;
}
.cs-media .cs-breadcrumbs a {
  color: #fff;
  background: rgba(0, 0, 0, 0.32);
  border-color: rgba(255, 255, 255, 0.22);
  -webkit-backdrop-filter: blur(8px);
  backdrop-filter: blur(8px);
}
.cs-media .cs-breadcrumbs a:hover {
  color: #fff;
  background: rgba(0, 0, 0, 0.55);
  border-color: rgba(255, 255, 255, 0.4);
}

/* ── Intro block ─────────────────────────────────────────────────────── */
.cs-intro { padding-block: var(--sp-2xl) var(--sp-xl); }

.cs-intro__top {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--sp-lg);
}
.cs-intro__title { margin: 0; max-width: 18ch; }
.cs-intro__client {
  flex-shrink: 0;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(1.1rem, 2.5vw, 1.75rem);
  letter-spacing: 0.02em;
  text-transform: uppercase;
  color: var(--clr-muted);
}

.cs-intro__divider {
  border: none;
  border-top: 1px solid var(--clr-border);
  margin: var(--sp-lg) 0 var(--sp-xl);
}

/* Meta row: Rok / Klient / Odvětví */
.cs-intro__meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-2xl);
  margin: 0 0 var(--sp-2xl);
}
.cs-intro__meta-item { display: flex; flex-direction: column; gap: 0.4rem; }
.cs-intro__meta-item dt {
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--clr-muted);
}
.cs-intro__meta-item dd {
  margin: 0;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(1.1rem, 2vw, 1.5rem);
  letter-spacing: -0.01em;
  color: var(--clr-text);
}
.cs-intro__live {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(1.1rem, 2vw, 1.5rem);
  color: var(--clr-accent);
  border-bottom: 1px solid currentColor;
  transition: opacity 0.2s;
}
.cs-intro__live:hover { opacity: 0.75; }

/* Detail row: Služby + Brief + Výsledek */
.cs-intro__detail {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-xl) var(--sp-2xl);
}
.cs-intro__col { flex: 1 1 16rem; min-width: 0; }
.cs-intro__col--services { flex: 0 0 auto; min-width: 8rem; }
.cs-intro__label {
  display: block;
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--clr-muted);
  margin-bottom: var(--sp-sm);
}
.cs-intro__tags { display: flex; flex-wrap: wrap; gap: var(--sp-xs); list-style: none; margin: 0; padding: 0; }
.cs-intro__tag {
  display: inline-block;
  font-size: 0.75rem;
  letter-spacing: 0.04em;
  padding: 0.35em 0.85em;
  border: 1px solid var(--clr-accent);
  border-radius: 999px;
  color: var(--clr-accent);
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
}
.cs-intro__tag:hover {
  background: var(--clr-accent);
  color: #fff;
}
.cs-intro__lead {
  margin: 0;
  font-size: clamp(0.95rem, 1.3vw, 1.05rem);
  line-height: 1.6;
  color: var(--clr-text);
  max-width: 36ch;
}

@media (max-width: 48em) {
  .cs-intro__top { flex-direction: column; align-items: flex-start; gap: var(--sp-sm); }
  .cs-intro__meta { gap: var(--sp-lg); }
  .cs-intro__detail { gap: var(--sp-lg); }
}

/* ── Gallery ─────────────────────────────────────────────────────────── */
.cs-gallery { padding-block: var(--sp-2xl); }
.cs-gallery__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-sm);
}
.cs-gallery__item {
  position: relative;
  display: block;
  padding: 0;
  border: none;
  border-radius: var(--radius-md);
  overflow: hidden;
  aspect-ratio: 4 / 5;
  background: var(--clr-surface);
  cursor: pointer;
}
.cs-gallery__media {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s var(--ease-out-expo);
}
.cs-gallery__item:hover .cs-gallery__media { transform: scale(1.04); }
.cs-gallery__zoom {
  position: absolute;
  top: 0.6rem;
  right: 0.6rem;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.4);
  color: #fff;
  -webkit-backdrop-filter: blur(6px);
  backdrop-filter: blur(6px);
  opacity: 0;
  transform: scale(0.85);
  transition: opacity 0.25s, transform 0.25s;
}
.cs-gallery__item:hover .cs-gallery__zoom { opacity: 1; transform: scale(1); }

@media (max-width: 48em) {
  .cs-gallery__grid { grid-template-columns: repeat(2, 1fr); }
}

/* ── Lightbox ────────────────────────────────────────────────────────── */
.cs-lightbox {
  position: fixed;
  inset: 0;
  z-index: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: clamp(1rem, 4vw, 3rem);
  background: rgba(8, 8, 7, 0.92);
  -webkit-backdrop-filter: blur(8px);
  backdrop-filter: blur(8px);
  opacity: 0;
  transition: opacity 0.25s ease;
}
.cs-lightbox.is-open { opacity: 1; }
.cs-lightbox__stage {
  display: flex;
  align-items: center;
  justify-content: center;
  max-width: min(92vw, 1100px);
  max-height: 88vh;
}
.cs-lightbox :global(.cs-lightbox__media) {
  max-width: min(92vw, 1100px);
  max-height: 88vh;
  width: auto;
  height: auto;
  border-radius: var(--radius-md);
  display: block;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
}
.cs-lightbox__close,
.cs-lightbox__nav {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: #fff;
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s;
  z-index: 2;
}
.cs-lightbox__close:hover,
