---
import Layout from '../../layouts/Layout.astro'
import PortableText from '../PortableText.astro'
import SanityImage from '../SanityImage.astro'
import { urlFor } from '../../lib/imageUrl'
import { useTranslations, type Lang } from '../../i18n/ui'

interface Props {
  lang: Lang
  slug: string
  cs: any
  allNav?: { slug: string; title: string; titleEn: string }[]
}

const { lang, slug, cs, allNav = [] } = Astro.props

// Hero video — Sanity heroVideo URL, with a local fallback for specific cases
const heroVideo = cs?.heroVideo || (slug === 'jatvar' ? '/work/jatvar-hero.mp4' : null)

// Prev / next
const navIdx  = allNav.findIndex(p => p.slug === slug)
const prevCs  = navIdx > 0 ? allNav[navIdx - 1] : null
const nextCs  = navIdx < allNav.length - 1 ? allNav[navIdx + 1] : null
const prevTitle = prevCs ? (lang === 'en' ? (prevCs.titleEn || prevCs.title) : prevCs.title) : null
const nextTitle = nextCs ? (lang === 'en' ? (nextCs.titleEn || nextCs.title) : nextCs.title) : null
const t = useTranslations(lang)

const title    = lang === 'en' ? (cs?.titleEn    || cs?.title)   : cs?.title
const tagline  = lang === 'en' ? (cs?.taglineEn  || cs?.tagline) : cs?.tagline
const seoDesc  = lang === 'en' ? (cs?.seoDescriptionEn || cs?.seoDescription || tagline) : (cs?.seoDescription || tagline)
const credits  = lang === 'en' ? (cs?.creditsEn  || cs?.credits) : cs?.credits

const workUrl      = lang === 'cs' ? '/work'          : '/en/work'
const alternateUrl = lang === 'cs' ? `/en/work/${slug}` : `/work/${slug}`
const homeUrl   = lang === 'cs' ? '/' : '/en'
const homeLabel = lang === 'cs' ? 'Domů' : 'Home'
const workLabel = lang === 'cs' ? 'Práce' : 'Work'

const ogImageUrl = cs?.coverImage
  ? urlFor(cs.coverImage).width(1200).height(630).fit('crop').format('webp').url()
  : undefined

const baseUrl = 'https://slant.cz'
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: homeLabel, item: `${baseUrl}${homeUrl}` },
    { '@type': 'ListItem', position: 2, name: workLabel, item: `${baseUrl}${workUrl}` },
    { '@type': 'ListItem', position: 3, name: title, item: `${baseUrl}${workUrl}/${slug}` },
  ],
}

const caseStudyLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: title,
  description: seoDesc,
  creator: { '@type': 'Organization', name: 'Slant s.r.o.', url: baseUrl },
  ...(cs?.year && { dateCreated: String(cs.year) }),
  ...(ogImageUrl && { image: ogImageUrl }),
  ...(cs?.services?.length && { keywords: cs.services.join(', ') }),
}
---

<Layout
  title={title ?? '404'}
  description={seoDesc}
  ogImage={ogImageUrl}
  extraLd={[breadcrumb, caseStudyLd]}
  {lang}
  {alternateUrl}
>
  {!cs ? (
    <div class="container" style="padding-block: var(--sp-3xl); color: var(--clr-muted)">
      {t('work.notFound')}
    </div>
  ) : (
    <article class="cs" data-sanity-document={cs._id}>
      <header class="cs-hero container">
        <nav class="breadcrumbs" aria-label="Breadcrumb" data-fade>
          <a href={homeUrl}>{homeLabel}</a>
          <a href={workUrl}>{workLabel}</a>
          <span aria-current="page">{title}</span>
        </nav>

        <h1
          class="cs-hero__title text-display"
          data-fade
          data-sanity={lang === 'en' ? 'titleEn' : 'title'}
        >{title}</h1>

        {tagline && (
          <p
            class="cs-hero__tagline"
            data-fade
            data-sanity={lang === 'en' ? 'taglineEn' : 'tagline'}
          >{tagline}</p>
        )}

        {cs.services?.length > 0 && (
          <ul class="cs-hero__tags" data-fade>
            {cs.services.map((s: string) => <li class="cs-hero__tag">{s}</li>)}
          </ul>
        )}

        <dl class="cs-hero__info" data-fade>
          {cs.client   && <><dt>{t('cs.client')}</dt>  <dd>{cs.client}</dd></>}
          {cs.year     && <><dt>{t('cs.year')}</dt>    <dd>{cs.year}</dd></>}
          {cs.industry && <><dt>{t('cs.industry')}</dt><dd>{cs.industry}</dd></>}
          {cs.liveUrl  && (
            <><dt>{t('cs.live')}</dt>
            <dd><a href={cs.liveUrl} target="_blank" rel="noopener" class="cs-hero__live">{t('work.viewSite')}</a></dd></>
          )}
        </dl>
      </header>

      <div class="cs-media" data-fade>
        {heroVideo ? (
          <video src={heroVideo} autoplay loop muted playsinline class="cs-media__video" />
        ) : cs.coverImage ? (
          <SanityImage
            image={cs.coverImage}
            alt={cs.coverImage.alt ?? title}
            width={1800}
            height={1012}
            widths={[800, 1200, 1800]}
            sizes="100vw"
            quality={90}
            loading="eager"
            class="cs-media__image"
          />
        ) : null}
      </div>

      {cs.sections?.length > 0 && (
        <div class="cs-sections container">
          {cs.sections.map((section: any) => {
            const heading = lang === 'en' ? (section.headingEn || section.heading) : section.heading
            const body    = lang === 'en' && section.bodyEn?.length ? section.bodyEn : section.body
            return (
              <section class="cs-section">
                {heading && <h2 class="cs-section__heading" data-fade>{heading}</h2>}
                {body?.length > 0 && (
                  <div class="cs-section__body" data-fade>
                    <PortableText blocks={body} />
                  </div>
                )}
                {section.images?.length > 0 && (
                  <div class="cs-section__images" data-count={section.images.length} data-fade>
                    {section.images.map((img: any) => {
                      const single = section.images.length === 1
                      return (
                        <figure class="cs-section__figure">
                          <SanityImage
                            image={img}
                            alt={img.alt ?? ''}
                            width={single ? 1800 : 1000}
                            height={single ? 1013 : 667}
                            widths={single ? [800, 1200, 1800] : [400, 700, 1000]}
                            sizes={single ? '100vw' : '(max-width: 768px) 100vw, 50vw'}
                            quality={88}
                            class="cs-section__img"
                          />
                          {img.caption && <figcaption class="cs-section__caption text-small">{img.caption}</figcaption>}
                        </figure>
                      )
                    })}
                  </div>
                )}
              </section>
            )
          })}
        </div>
      )}

      {credits && (
        <footer class="cs-credits container" data-fade>
          <p class="text-small" style="color: var(--clr-muted)">{credits}</p>
        </footer>
      )}

      <!-- ─── Case study nav ─────────────────────────────────────────── -->
      <nav class="cs-nav container" aria-label="Další projekty">

        {prevCs ? (
          <a href={`${workUrl}/${prevCs.slug}`} class="cs-nav__item cs-nav__item--prev">
            {prevCs.coverImage && (
              <div class="cs-nav__thumb">
                <SanityImage image={prevCs.coverImage} alt={prevTitle ?? ''} width={320} height={200} widths={[320]} sizes="160px" class="cs-nav__thumb-img" />
              </div>
            )}
            <div class="cs-nav__text">
              <span class="cs-nav__label">
                <svg width="14" height="14" viewBox="0 0 20 20" fill="none">
                  <path d="M16 10H4M8 14l-4-4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {lang === 'cs' ? 'Předchozí' : 'Previous'}
              </span>
              <span class="cs-nav__title">{prevTitle}</span>
            </div>
          </a>
        ) : <span />}

        <a href={workUrl} class="cs-nav__grid" aria-label={lang === 'cs' ? 'Všechny projekty' : 'All projects'}>
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
            <rect x="2" y="2" width="6" height="6" rx="1" fill="currentColor"/>
            <rect x="12" y="2" width="6" height="6" rx="1" fill="currentColor"/>
            <rect x="2" y="12" width="6" height="6" rx="1" fill="currentColor"/>
            <rect x="12" y="12" width="6" height="6" rx="1" fill="currentColor"/>
          </svg>
        </a>

        {nextCs ? (
          <a href={`${workUrl}/${nextCs.slug}`} class="cs-nav__item cs-nav__item--next">
            <div class="cs-nav__text cs-nav__text--right">
              <span class="cs-nav__label">
                {lang === 'cs' ? 'Další' : 'Next'}
                <svg width="14" height="14" viewBox="0 0 20 20" fill="none">
                  <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="cs-nav__title">{nextTitle}</span>
            </div>
            {nextCs.coverImage && (
              <div class="cs-nav__thumb">
                <SanityImage image={nextCs.coverImage} alt={nextTitle ?? ''} width={320} height={200} widths={[320]} sizes="160px" class="cs-nav__thumb-img" />
              </div>
            )}
          </a>
        ) : <span />}

      </nav>
    </article>
  )}
</Layout>

<style>
.cs-hero { padding-block: var(--sp-2xl); }
.cs-hero__meta { margin-bottom: var(--sp-lg); }
.cs-hero__title { max-width: 14ch; margin-bottom: var(--sp-md); }
.cs-hero__tagline { font-size: clamp(1.1rem, 2vw, 1.5rem); color: var(--clr-muted); max-width: 40ch; line-height: 1.4; margin-bottom: var(--sp-lg); }
.cs-hero__tags { display: flex; flex-wrap: wrap; gap: var(--sp-xs); list-style: none; margin-bottom: var(--sp-lg); }
.cs-hero__tag { font-size: 0.75rem; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.3em 0.75em; border: 1px solid var(--clr-border); border-radius: 999px; color: var(--clr-muted); }
.cs-hero__info { display: grid; grid-template-columns: auto 1fr; gap: 0.25rem 1.5rem; font-size: 0.875rem; max-width: 28rem; }
.cs-hero__info dt { color: var(--clr-muted); font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; padding-top: 0.1em; }
.cs-hero__live { opacity: 0.7; border-bottom: 1px solid currentColor; transition: opacity 0.2s; }
.cs-hero__live:hover { opacity: 1; }
.cs-media { width: 100%; aspect-ratio: 16 / 9; overflow: hidden; background: var(--clr-surface); }
.cs-media__video,
.cs-media :global(picture),
.cs-media :global(.cs-media__image) { width: 100%; height: 100%; display: block; }
.cs-media :global(picture img),
.cs-media :global(.cs-media__image) { object-fit: cover; width: 100%; height: 100%; }
.cs-sections { padding-block: var(--sp-3xl); display: flex; flex-direction: column; gap: var(--sp-3xl); }
.cs-section { display: grid; grid-template-columns: 1fr 2fr; gap: var(--sp-lg) var(--sp-xl); padding-top: var(--sp-xl); border-top: 1px solid var(--clr-border); }
@media (max-width: 56em) { .cs-section { grid-template-columns: 1fr; gap: var(--sp-md); } }
.cs-section__heading { font-family: var(--font-sans); font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--clr-muted); font-weight: 400; padding-top: 0.2em; }
.cs-section__body { font-size: clamp(1rem, 1.3vw, 1.125rem); line-height: 1.7; color: var(--clr-text); }
.cs-section__body:first-child { grid-column: 1 / -1; }
.cs-section__images { grid-column: 1 / -1; display: grid; gap: var(--sp-sm); }
.cs-section__images[data-count="1"] { grid-template-columns: 1fr; }
.cs-section__images[data-count="2"] { grid-template-columns: 1fr 1fr; }
.cs-section__images[data-count="3"] { grid-template-columns: 1fr 1fr 1fr; }
.cs-section__images[data-count="4"] { grid-template-columns: 1fr 1fr; }
@media (max-width: 48em) {
  .cs-section__images[data-count="2"],
  .cs-section__images[data-count="3"],
  .cs-section__images[data-count="4"] { grid-template-columns: 1fr; }
}
.cs-section__figure { overflow: hidden; border-radius: var(--radius-md); background: var(--clr-surface); }
.cs-section__figure :global(picture),
.cs-section__figure :global(.cs-section__img) { display: block; width: 100%; height: 100%; }
.cs-section__figure :global(picture img),
.cs-section__figure :global(.cs-section__img) { width: 100%; aspect-ratio: 3 / 2; object-fit: cover; display: block; }
.cs-section__caption { padding: var(--sp-xs) var(--sp-sm); color: var(--clr-muted); }
.cs-credits { padding-block: var(--sp-xl); border-top: 1px solid var(--clr-border); }

/* ── Case study nav ────────────────────────────────────────────────────── */
.cs-nav {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: var(--sp-lg);
  padding-block: var(--sp-2xl);
  border-top: 1px solid var(--clr-border);
  margin-top: var(--sp-xl);
}

/* Each side: thumbnail + text side by side */
.cs-nav__item {
  display: flex;
  align-items: center;
  gap: var(--sp-md);
  padding: var(--sp-sm) var(--sp-md);
  border-radius: var(--radius-lg);
  transition: background 0.2s, opacity 0.2s;
}
.cs-nav__item:hover { background: var(--clr-surface); }

.cs-nav__item--next { justify-content: flex-end; }

/* Thumbnail */
.cs-nav__thumb {
  flex-shrink: 0;
  width: clamp(64px, 8vw, 100px);
  aspect-ratio: 3 / 2;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--clr-surface);
}
.cs-nav__thumb-img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.4s ease;
}
.cs-nav__item:hover .cs-nav__thumb-img { transform: scale(1.06); }

/* Text block */
.cs-nav__text {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}
.cs-nav__text--right { align-items: flex-end; }

.cs-nav__label {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.7rem;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  color: var(--clr-accent);
  font-style: italic;
  font-weight: 500;
}

.cs-nav__title {
  font-family: var(--font-display);
  font-size: clamp(0.95rem, 1.8vw, 1.35rem);
  font-weight: 400;
  letter-spacing: -0.02em;
  color: var(--clr-text);
  line-height: 1.15;
}

/* Grid icon — centre */
.cs-nav__grid {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2.75rem;
  height: 2.75rem;
  border-radius: 50%;
  border: 1px solid var(--clr-border);
  color: var(--clr-muted);
  flex-shrink: 0;
  transition: color 0.2s, border-color 0.2s, background 0.2s;
}
.cs-nav__grid:hover {
  color: var(--clr-text);
  border-color: var(--clr-text);
  background: color-mix(in srgb, var(--clr-text) 5%, transparent);
}

@media (max-width: 48em) {
  .cs-nav {
    grid-template-columns: 1fr;
    gap: var(--sp-sm);
  }

  /* Grid ikona nahoře, prev, next */
  .cs-nav__grid       { order: -1; margin: 0 auto var(--sp-xs); }
  .cs-nav__item--prev { order: 0; }
  .cs-nav__item--next { order: 1; }

  /* Tiles: always show bg */
  .cs-nav__item {
    background: var(--clr-surface);
    border-radius: var(--radius-lg);
    padding: var(--sp-md);
    justify-content: space-between;
    align-items: center;
    gap: var(--sp-sm);
    width: 100%;
  }
  .cs-nav__item:hover { background: var(--clr-surface); }

  /* Prev: text left, image right */
  .cs-nav__item--prev { flex-direction: row; }

  /* Next: image left, text right */
  .cs-nav__item--next { flex-direction: row-reverse; }
  .cs-nav__text--right { align-items: flex-end; }

  .cs-nav__thumb { width: 64px; flex-shrink: 0; }
  .cs-nav__title { font-size: 0.9rem; }
  .cs-nav__label { font-size: 0.65rem; }
}
</style>
