---
import Layout from '../../layouts/Layout.astro'
import CaseStudyCard from '../CaseStudyCard.astro'
import { client } from '../../lib/sanity'
import { ALL_CASE_STUDIES_QUERY } from '../../lib/queries'
import { useTranslations, type Lang } from '../../i18n/ui'

interface Props { lang: Lang }

const { lang } = Astro.props
const t = useTranslations(lang)
const caseStudies = await client.fetch(ALL_CASE_STUDIES_QUERY)
const alternateUrl = lang === 'cs' ? '/en/work' : '/work'

const homeUrl = lang === 'cs' ? '/' : '/en'
const workUrl = lang === 'cs' ? '/work' : '/en/work'
const homeLabel = lang === 'cs' ? 'Domů' : 'Home'
const workLabel = lang === 'cs' ? 'Práce' : 'Work'

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: homeLabel, item: `https://slant.cz${homeUrl}` },
    { '@type': 'ListItem', position: 2, name: workLabel, item: `https://slant.cz${workUrl}` },
  ],
}

// Collect all unique tags + counts
const allTags: string[] = [...new Set(
  caseStudies.flatMap((cs: any) => cs.services ?? [])
)].sort() as string[]
const tagCount = (tag: string) =>
  caseStudies.filter((cs: any) => (cs.services ?? []).includes(tag)).length
---

<Layout
  title={t('meta.work.title')}
  description={t('meta.work.desc')}
  {lang}
  {alternateUrl}
  extraLd={[breadcrumbLd]}
>
  <section class="work-listing container">
    <nav class="breadcrumbs" aria-label="Breadcrumb" data-fade>
      <a href={homeUrl}>{homeLabel}</a>
      <span aria-current="page">{workLabel}</span>
    </nav>

    <header class="page-header" data-fade>
      <h1 class="page-header__title">Work</h1>
    </header>

    <!-- Tag filters with counts -->
    {allTags.length > 0 && (
      <div class="work-listing__filters" id="tag-filters">
        <button class="tag-btn tag-btn--all is-active" data-tag="">
          {lang === 'cs' ? 'Vše' : 'All'} <span class="tag-btn__count">{caseStudies?.length ?? 0}</span>
        </button>
        {allTags.map(tag => (
          <button class="tag-btn" data-tag={tag}>
            {tag} <span class="tag-btn__count">{tagCount(tag)}</span>
          </button>
        ))}
      </div>
    )}

    {caseStudies?.length > 0 ? (
      <div class="work-listing__grid" id="work-grid">
        {caseStudies.map((cs: any) => (
          <div
            class="work-listing__card"
            data-services={JSON.stringify(cs.services ?? [])}
          >
            <CaseStudyCard
              title={lang === 'en' ? (cs.titleEn || cs.title) : cs.title}
              slug={cs.slug}
              tagline={lang === 'en' ? (cs.taglineEn || cs.tagline) : cs.tagline}
              year={cs.year}
              services={cs.services}
              coverImage={cs.coverImage}
              featured={cs.featured}
              {lang}
            />
          </div>
        ))}
      </div>
    ) : (
      <p class="work-listing__empty text-body" style="color: var(--clr-muted)">
        {t('work.empty')}
      </p>
    )}
  </section>
</Layout>

<script>
  const params   = new URLSearchParams(window.location.search)
  const initTag  = params.get('tag') ?? ''

  const filters  = document.getElementById('tag-filters')
  const grid     = document.getElementById('work-grid')
  const cards    = grid?.querySelectorAll<HTMLElement>('.work-listing__card')
  const btns     = filters?.querySelectorAll<HTMLButtonElement>('.tag-btn')

  function applyFilter(tag: string) {
    if (!cards || !btns) return

    btns.forEach(b => b.classList.toggle('is-active', b.dataset.tag === tag))

    cards.forEach(card => {
      const services: string[] = JSON.parse(card.dataset.services ?? '[]')
      const show = !tag || services.includes(tag)
      card.style.display = show ? '' : 'none'
    })

    // update URL without reload
    const url = new URL(window.location.href)
    tag ? url.searchParams.set('tag', tag) : url.searchParams.delete('tag')
    history.replaceState({}, '', url)
  }

  // Init from URL param
  applyFilter(initTag)

  // Click handlers
  btns?.forEach(btn => {
    btn.addEventListener('click', () => applyFilter(btn.dataset.tag ?? ''))
  })
</script>

<style>
.work-listing { padding-block: var(--sp-2xl) var(--sp-3xl); }

/* Tag filters */
.work-listing__filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: var(--sp-xl);
}

.tag-btn {
  padding: 0.35em 0.9em;
  border-radius: 999px;
  border: 1px solid var(--clr-border);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--clr-muted);
  transition: color 0.2s, border-color 0.2s, background 0.2s;
  cursor: pointer;
}
.tag-btn:hover,
.tag-btn.is-active {
  color: var(--clr-text);
  border-color: var(--clr-text);
  background: color-mix(in srgb, var(--clr-text) 6%, transparent);
}
.tag-btn__count {
  opacity: 0.5;
  font-variant-numeric: tabular-nums;
  margin-left: 0.15em;
}
.tag-btn.is-active .tag-btn__count { opacity: 0.7; }

.work-listing__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 28rem), 1fr));
  gap: var(--sp-sm);
}

.work-listing__empty { padding-top: var(--sp-xl); }
</style>
