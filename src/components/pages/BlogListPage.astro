---
import Layout from '../../layouts/Layout.astro'
import SanityImage from '../SanityImage.astro'
import { client } from '../../lib/sanity'
import { ALL_BLOG_POSTS_QUERY } from '../../lib/queries'
import { useTranslations, type Lang } from '../../i18n/ui'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)

const posts = await client.fetch(ALL_BLOG_POSTS_QUERY)

const blogUrl = lang === 'cs' ? '/blog' : '/en/blog'
const alternateUrl = lang === 'cs' ? '/en/blog' : '/blog'

const homeUrl = lang === 'cs' ? '/' : '/en'
const homeLabel = lang === 'cs' ? 'Domů' : 'Home'
const blogLabel = 'Blog'

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: homeLabel, item: `https://slant.cz${homeUrl}` },
    { '@type': 'ListItem', position: 2, name: blogLabel, item: `https://slant.cz${blogUrl}` },
  ],
}

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString(
    lang === 'cs' ? 'cs-CZ' : 'en-GB',
    { day: 'numeric', month: 'long', year: 'numeric' }
  )
}

function postTitle(post: any) {
  return lang === 'en' ? (post.titleEn || post.title) : post.title
}

function postDesc(post: any) {
  return lang === 'en' ? (post.descriptionEn || post.description) : post.description
}

const featuredPost = posts.find((p: any) => p.featured) ?? posts[0] ?? null
const listPosts = posts.filter((p: any) => p !== featuredPost)

// Unique categories for filtering + counts
const allCategories: string[] = [...new Set(
  posts.map((p: any) => p.category).filter(Boolean)
)].sort() as string[]
const catCount = (cat: string) => posts.filter((p: any) => p.category === cat).length
---

<Layout
  title={lang === 'cs' ? 'Blog – Ze studia | Slant' : 'Blog – From the studio | Slant'}
  description={lang === 'cs' ? 'Články a postřehy ze studia Slant.' : 'Articles and insights from Slant studio.'}
  {lang}
  {alternateUrl}
  extraLd={[breadcrumbLd]}
>
  <section class="blog-listing container">

    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href={homeUrl}>{homeLabel}</a>
    </nav>

    <!-- Header -->
    <header class="page-header">
      <h1 class="page-header__title">{lang === 'cs' ? 'Ze studia' : 'From the studio'}</h1>
    </header>

    <!-- Category filters with counts -->
    {allCategories.length > 0 && (
      <div class="blog-filters" id="blog-filters">
        <button class="tag-btn is-active" data-cat="">
          {lang === 'cs' ? 'Vše' : 'All'} <span class="tag-btn__count">{posts.length}</span>
        </button>
        {allCategories.map(cat => (
          <button class="tag-btn" data-cat={cat}>
            {cat} <span class="tag-btn__count">{catCount(cat)}</span>
          </button>
        ))}
      </div>
    )}

    {posts.length === 0 ? (
      <p class="empty-state">
        {lang === 'cs' ? 'Brzy přibydou první články' : 'Articles coming soon'}
      </p>
    ) : (
      <>
        <!-- Featured post -->
        {featuredPost && (
          <a href={`${blogUrl}/${featuredPost.slug}`} class="featured-post" data-featured data-category={featuredPost.category ?? ''}>
            <div class="featured-post__image">
              {featuredPost.coverImage && (
                <SanityImage
                  image={featuredPost.coverImage}
                  alt={featuredPost.coverImage.alt ?? postTitle(featuredPost)}
                  width={900}
                  height={600}
                  widths={[600, 900, 1200]}
                  sizes="(max-width: 48em) 100vw, 60vw"
                  class="featured-post__img"
                />
              )}
            </div>
            <div class="featured-post__content">
              {featuredPost.category && (
                <span class="chip">{featuredPost.category}</span>
              )}
              {featuredPost.publishedAt && (
                <time class="featured-post__date" datetime={featuredPost.publishedAt}>
                  {formatDate(featuredPost.publishedAt)}
                </time>
              )}
              <h2 class="featured-post__title">{postTitle(featuredPost)}</h2>
              {postDesc(featuredPost) && (
                <p class="featured-post__desc">{postDesc(featuredPost)}</p>
              )}
              <span class="featured-post__cta">
                {lang === 'cs' ? 'Číst článek →' : 'Read article →'}
              </span>
            </div>
          </a>
        )}

        <!-- Editorial list -->
        {listPosts.length > 0 && (
          <ul class="blog-list" role="list">
            {listPosts.map((post: any) => {
              const postHref = `${blogUrl}/${post.slug}`
              const chars = (lang === 'en' ? post.bodyCharsEn : post.bodyChars) || post.bodyChars || 0
              const readMin = Math.max(1, Math.round(chars / 1100))
              return (
                <li class="blog-list__item" data-list-item data-category={post.category ?? ''}>
                  <a href={postHref} class="blog-list__thumb" aria-label={postTitle(post)} tabindex="-1">
                    {post.coverImage && (
                      <SanityImage
                        image={post.coverImage}
                        alt={post.coverImage.alt ?? postTitle(post)}
                        width={440}
                        height={293}
                        widths={[240, 440]}
                        sizes="(max-width: 48em) 35vw, 220px"
                        class="blog-list__thumb-img"
                      />
                    )}
                  </a>
                  <div class="blog-list__body">
                    {post.category && (
                      <a href={`${blogUrl}?category=${encodeURIComponent(post.category)}`} class="chip blog-list__tag">{post.category}</a>
                    )}
                    <a href={postHref} class="blog-list__title-link">
                      <span class="blog-list__title">{postTitle(post)}</span>
                    </a>
                    <div class="blog-list__foot">
                      {post.publishedAt && (
                        <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>
                      )}
                      <span class="blog-list__read">{readMin} {lang === 'cs' ? 'min čtení' : 'min read'}</span>
                    </div>
                  </div>
                </li>
              )
            })}
          </ul>
        )}
      </>
    )}
  </section>
</Layout>

<style>
.blog-listing {
  padding-block: var(--sp-2xl) var(--sp-3xl);
}

/* Empty state */
.empty-state {
  color: var(--clr-muted);
  font-size: 1rem;
  padding-block: var(--sp-xl);
}

/* Chip */
.chip {
  display: inline-block;
  padding: 0.25em 0.75em;
  border-radius: 999px;
  border: 1px solid var(--clr-border);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--clr-muted);
}

/* ── Category filters ──────────────────────────────────────────────── */
.blog-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: var(--sp-2xl);
}

.tag-btn {
  padding: 0.35em 0.9em;
  border-radius: 999px;
  border: 1px solid var(--clr-border);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--clr-muted);
  transition: color 0.2s, border-color 0.2s, background 0.2s;
  cursor: pointer;
}
.tag-btn:hover,
.tag-btn.is-active {
  color: var(--clr-text);
  border-color: var(--clr-text);
  background: color-mix(in srgb, var(--clr-text) 6%, transparent);
}
.tag-btn__count {
  opacity: 0.5;
  font-variant-numeric: tabular-nums;
  margin-left: 0.15em;
}
.tag-btn.is-active .tag-btn__count { opacity: 0.7; }

/* ── Featured post ─────────────────────────────────────────────────── */
.featured-post {
  display: grid;
  grid-template-columns: 3fr 2fr;
  gap: var(--sp-xl);
  align-items: center;
  margin-bottom: var(--sp-3xl);
  text-decoration: none;
  color: inherit;
}

.featured-post__image {
  aspect-ratio: 3 / 2;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--clr-surface);
}
.featured-post__image :global(picture),
.featured-post__image :global(.featured-post__img) {
  display: block;
  width: 100%;
  height: 100%;
}
.featured-post__image :global(picture img),
.featured-post__image :global(.featured-post__img) {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease, opacity 0.3s ease;
}
.featured-post:hover .featured-post__image :global(picture img),
.featured-post:hover .featured-post__image :global(.featured-post__img) {
  transform: scale(1.03);
}

.featured-post__content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--sp-sm);
}
.featured-post__date {
  font-size: 0.75rem;
  color: var(--clr-muted);
  letter-spacing: 0.06em;
  margin-top: var(--sp-xs);
}
.featured-post__title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 3.5rem);
  font-weight: 400;
  letter-spacing: -0.04em;
  line-height: 1.05;
  color: var(--clr-text);
  margin: 0;
}
.featured-post__desc {
  font-size: clamp(0.9rem, 1.3vw, 1.05rem);
  color: var(--clr-muted);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  max-width: 48ch;
}
.featured-post__cta {
  font-size: 0.85rem;
  color: var(--clr-accent);
  font-weight: 500;
  letter-spacing: 0.02em;
  margin-top: var(--sp-xs);
  transition: opacity 0.2s;
}
.featured-post:hover .featured-post__cta { opacity: 0.7; }

@media (max-width: 48em) {
  .featured-post {
    grid-template-columns: 1fr;
  }
  .featured-post__title {
    font-size: clamp(1.75rem, 6vw, 2.5rem);
  }
}

/* ── Editorial list ─────────────────────────────────────────────────── */
.blog-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.blog-list__item {
  display: flex;
  gap: var(--sp-lg);
  align-items: stretch;
  border-top: 1px solid var(--clr-border);
  padding-block: var(--sp-lg);
}
.blog-list__item:last-child { border-bottom: 1px solid var(--clr-border); }

/* Image — left, larger */
.blog-list__thumb {
  flex: 0 0 auto;
  width: clamp(8rem, 26vw, 14rem);
  aspect-ratio: 3 / 2;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--clr-surface);
  display: block;
}
.blog-list__thumb-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}
.blog-list__thumb:hover .blog-list__thumb-img { transform: scale(1.05); }

/* Content */
.blog-list__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--sp-xs);
}
.blog-list__tag {
  cursor: pointer;
  transition: color 0.2s, border-color 0.2s, background 0.2s;
}
.blog-list__tag:hover {
  color: #fff;
  background: var(--clr-accent);
  border-color: var(--clr-accent);
}
.blog-list__title-link { text-decoration: none; color: inherit; }
.blog-list__title {
  font-family: var(--font-display);
  font-size: clamp(1.25rem, 2.4vw, 2rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--clr-text);
  line-height: 1.1;
  transition: color 0.2s;
}
.blog-list__title-link:hover .blog-list__title { color: var(--clr-accent); }

.blog-list__foot {
  margin-top: auto;
  padding-top: var(--sp-sm);
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.75rem;
  letter-spacing: 0.04em;
  color: var(--clr-muted);
}
.blog-list__foot .blog-list__read::before { content: '·'; margin-right: 0.5rem; }

@media (max-width: 40em) {
  .blog-list__item { gap: var(--sp-md); }
  .blog-list__thumb { width: clamp(6rem, 32vw, 9rem); }
}
</style>

<script>
import { gsap } from 'gsap'
import { ScrollTrigger } from 'gsap/ScrollTrigger'

gsap.registerPlugin(ScrollTrigger)

// ── Category filtering ───────────────────────────────────────────────
const filters  = document.getElementById('blog-filters')
if (filters) {
  const btns     = filters.querySelectorAll<HTMLButtonElement>('.tag-btn')
  const featured = document.querySelector<HTMLElement>('[data-featured]')
  const items    = document.querySelectorAll<HTMLElement>('[data-list-item]')

  const params  = new URLSearchParams(window.location.search)
  const initCat = params.get('category') ?? ''

  function applyFilter(cat: string) {
    btns.forEach(b => b.classList.toggle('is-active', b.dataset.cat === cat))

    const toggle = (el: HTMLElement | null) => {
      if (!el) return
      const show = !cat || el.dataset.category === cat
      el.style.display = show ? '' : 'none'
    }

    toggle(featured)
    items.forEach(toggle)

    const url = new URL(window.location.href)
    cat ? url.searchParams.set('category', cat) : url.searchParams.delete('category')
    history.replaceState({}, '', url)
  }

  applyFilter(initCat)
  btns.forEach(btn => btn.addEventListener('click', () => applyFilter(btn.dataset.cat ?? '')))
}

// Featured post animation
const featured = document.querySelector('[data-featured]')
if (featured) {
  gsap.from(featured, {
    y: 40,
    opacity: 0,
    duration: 0.9,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: featured,
      start: 'top 85%',
    },
  })
}

// List rows stagger
const items = document.querySelectorAll('[data-list-item]')
if (items.length) {
  gsap.from(items, {
    y: 20,
    opacity: 0,
    duration: 0.6,
    ease: 'power2.out',
    stagger: 0.07,
    scrollTrigger: {
      trigger: items[0],
      start: 'top 90%',
    },
  })
}
</script>
