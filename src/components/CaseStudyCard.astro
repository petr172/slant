---
import SanityImage from './SanityImage.astro'

interface Props {
  title: string
  slug: string
  tagline?: string
  year?: number
  services?: string[]
  coverImage?: any
  cardVideo?: string
  cardImageFallback?: string
  featured?: boolean
  lang?: 'cs' | 'en'
  variant?: 'default' | 'home' | 'wide'
  headingLevel?: 2 | 3
}

const {
  title, slug, tagline, services, coverImage,
  lang = 'cs', variant = 'default', headingLevel = 2,
} = Astro.props

const workBase = lang === 'en' ? '/en/work' : '/work'

// Optional hover-play video (Sanity field)
const cardVideo = Astro.props.cardVideo

const Heading = (headingLevel === 3 ? 'h3' : 'h2') as 'h2' | 'h3'

// Image sizing per variant
const dims = variant === 'wide'
  ? { width: 1400, height: 800, widths: [700, 1100, 1400], sizes: '(max-width: 768px) 100vw, 70vw' }
  : variant === 'home'
    ? { width: 900, height: 600, widths: [450, 700, 900], sizes: '(max-width: 768px) 100vw, 40vw' }
    : { width: 900, height: 600, widths: [400, 700, 900], sizes: '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw' }
---

<article class={`case-card case-card--${variant}${cardVideo ? ' case-card--has-video' : ''}`} data-fade>
  <a href={`${workBase}/${slug}`} class="case-card__link">
    <div class="case-card__media">
      {coverImage
        ? <SanityImage
            image={coverImage}
            alt={coverImage?.alt ?? title}
            width={dims.width}
            height={dims.height}
            widths={dims.widths}
            sizes={dims.sizes}
            class="case-card__img"
          />
        : <div class="case-card__placeholder" aria-hidden="true" />
      }
      {cardVideo && (
        <video class="case-card__video" data-card-video src={cardVideo} muted loop playsinline preload="none" aria-hidden="true"></video>
      )}
    </div>
    <div class="case-card__info">
      <Heading class="case-card__title">{title}</Heading>
      {tagline && <p class="case-card__tagline">{tagline}</p>}
    </div>
  </a>

  {services?.length ? (
    <div class="case-card__tags">
      {services.slice(0, 3).map(s => (
        <a href={`${workBase}?tag=${encodeURIComponent(s)}`} class="case-card__tag">{s}</a>
      ))}
    </div>
  ) : null}
</article>

<style>
.case-card {
  position: relative;
  display: flex;
  flex-direction: column;
  padding: var(--sp-sm);
  border-radius: var(--radius-md);
  transition: background 0.25s ease;
}
.case-card--wide { grid-column: 1 / -1; }

/* Hover celé karty jako u FAQ položek / navbar tlačítek */
@media (hover: hover) {
  .case-card:hover { background: color-mix(in srgb, var(--clr-text) 6%, transparent); }
}

.case-card__link { display: block; text-decoration: none; color: inherit; }

.case-card__media {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3 / 2;
  background: var(--clr-surface);
  border-radius: var(--radius-md);
  margin-bottom: var(--sp-sm);
}
.case-card--home .case-card__media { aspect-ratio: 16 / 9; }
.case-card--wide .case-card__media { aspect-ratio: 21 / 9; }
@media (max-width: 56em) {
  .case-card--wide .case-card__media { aspect-ratio: 16 / 9; }
}

.case-card__media :global(picture),
.case-card__media :global(.case-card__img) {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s var(--ease-out-expo);
}

/* Scénář B — bez videa: plynulý zoom obrázku o 10 % na hover */
.case-card:not(.case-card--has-video) .case-card__link:hover :global(.case-card__img) { transform: scale(1.1); }

/* Scénář A — s videem: default obrázek, hover přehraje video ve smyčce.
   Video se zviditelní až když opravdu hraje (žádné bliknutí černé). */
.case-card__video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
}
.case-card__video.is-playing { opacity: 1; }

.case-card__placeholder { width: 100%; height: 100%; background: var(--clr-surface); }

.case-card__info { padding-block: var(--sp-xs); }

.case-card__title {
  font-family: var(--font-sans);
  font-size: clamp(1rem, 1.5vw, 1.25rem);
  font-weight: 400;
  letter-spacing: -0.01em;
  margin-bottom: var(--sp-2xs);
}
.case-card--wide .case-card__title { font-size: clamp(1.2rem, 2vw, 1.6rem); }

.case-card__tagline {
  font-size: 0.875rem;
  color: var(--clr-muted);
  line-height: 1.4;
}

.case-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
  margin-top: var(--sp-sm);
}
.case-card__tag {
  display: inline-block;
  padding: 0.25em 0.65em;
  border-radius: 999px;
  border: 1px solid var(--clr-border);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--clr-muted);
  transition: color 0.2s, border-color 0.2s, background 0.2s;
}
.case-card__tag:hover {
  color: #fff;
  background: var(--clr-accent);
  border-color: var(--clr-accent);
}
</style>

<script>
  // Hover-play card videos (runs once for all cards)
  document.querySelectorAll<HTMLVideoElement>('[data-card-video]').forEach(video => {
    const card = video.closest('.case-card')
    if (!card) return
    // Fade in only once frames are actually rendering → no black flash
    video.addEventListener('playing', () => video.classList.add('is-playing'))
    card.addEventListener('mouseenter', () => { video.play().catch(() => {}) })
    card.addEventListener('mouseleave', () => {
      video.classList.remove('is-playing')
      video.pause()
      video.currentTime = 0
    })
  })
</script>
