---
import SanityImage from './SanityImage.astro'

interface Props {
  title: string
  slug: string
  tagline?: string
  year?: number
  services?: string[]
  coverImage?: any
  featured?: boolean
  cardVideo?: string
  lang?: 'cs' | 'en'
}

const { title, slug, tagline, year, services, coverImage, lang = 'cs' } = Astro.props
const workBase = lang === 'en' ? '/en/work' : '/work'

// Optional hover-play video (Sanity field later; local fallback for now)
const cardVideo = Astro.props.cardVideo ?? (slug === 'jatvar' ? '/work/jatvar-hero.mp4' : undefined)
---

<article class="case-card" data-fade>
  <a href={`${workBase}/${slug}`} class="case-card__link">
    <div class="case-card__media">
      {coverImage
        ? <SanityImage
            image={coverImage}
            alt={coverImage?.alt ?? title}
            width={900}
            height={600}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
            widths={[400, 700, 900]}
            class="case-card__img"
          />
        : <div class="case-card__placeholder" aria-hidden="true" />
      }
      {cardVideo && (
        <video class="case-card__video" data-card-video src={cardVideo} muted loop playsinline preload="none" aria-hidden="true"></video>
      )}
    </div>
    <div class="case-card__info">
      <h2 class="case-card__title">{title}</h2>
      {tagline && <p class="case-card__tagline">{tagline}</p>}
      <div class="case-card__meta">
        {year && <span class="case-card__year">{year}</span>}
        {services?.length && (
          <ul class="case-card__services">
            {services.map(s => <li>{s}</li>)}
          </ul>
        )}
      </div>
    </div>
  </a>
</article>

<style>
.case-card { position: relative; }
.case-card__link { display: block; }

.case-card__media {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3 / 2;
  background: var(--clr-surface);
  border-radius: var(--radius-md);
  margin-bottom: var(--sp-sm);
}

.case-card__media picture,
.case-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s var(--ease-out-expo);
}

.case-card__link:hover .case-card__img { transform: scale(1.04); }

/* Hover-play video overlay */
.case-card__video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
}
.case-card__link:hover .case-card__video { opacity: 1; }

.case-card__placeholder { width: 100%; height: 100%; background: var(--clr-surface); }
.case-card__info { padding-block: var(--sp-xs); }

.case-card__title {
  font-family: var(--font-sans);
  font-size: clamp(1rem, 1.5vw, 1.25rem);
  font-weight: 400;
  letter-spacing: -0.01em;
  margin-bottom: var(--sp-2xs);
}

.case-card__tagline {
  font-size: 0.875rem;
  color: var(--clr-muted);
  line-height: 1.4;
  margin-bottom: var(--sp-xs);
}

.case-card__meta {
  display: flex;
  align-items: center;
  gap: var(--sp-sm);
  font-size: 0.75rem;
  color: var(--clr-muted);
}

.case-card__services {
  display: flex; flex-wrap: wrap; gap: 0.25rem; list-style: none;
}
.case-card__services li::before { content: '·'; margin-right: 0.25rem; }
.case-card__services li:first-child::before { content: ''; margin-right: 0; }
</style>

<script>
  // Hover-play card videos (runs once for all cards)
  document.querySelectorAll<HTMLVideoElement>('[data-card-video]').forEach(video => {
    const card = video.closest('.case-card')
    if (!card) return
    card.addEventListener('mouseenter', () => { video.play().catch(() => {}) })
    card.addEventListener('mouseleave', () => { video.pause(); video.currentTime = 0 })
  })
</script>
