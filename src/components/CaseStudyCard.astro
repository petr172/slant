---
// CaseStudyCard.astro
// Karta case study pro listing stránku.
// Vizuální design je na tobě — tady je jen struktura s CSS proměnnými.

import { urlFor } from '../lib/imageUrl'

interface Props {
  title: string
  slug: string
  tagline?: string
  year?: number
  services?: string[]
  coverImage?: any
  featured?: boolean
}

const { title, slug, tagline, year, services, coverImage } = Astro.props

const imgUrl = coverImage
  ? urlFor(coverImage).width(900).height(600).fit('crop').format('webp').quality(85).url()
  : null
---

<article class="case-card" data-fade>
  <a href={`/work/${slug}`} class="case-card__link">
    <div class="case-card__media">
      {imgUrl
        ? <img src={imgUrl} alt={coverImage?.alt ?? title} loading="lazy" width="900" height="600" />
        : <div class="case-card__placeholder" aria-hidden="true" />
      }
    </div>
    <div class="case-card__info">
      <h2 class="case-card__title">{title}</h2>
      {tagline && <p class="case-card__tagline">{tagline}</p>}
      <div class="case-card__meta">
        {year && <span class="case-card__year">{year}</span>}
        {services?.length && (
          <ul class="case-card__services">
            {services.map(s => <li>{s}</li>)}
          </ul>
        )}
      </div>
    </div>
  </a>
</article>

<style>
.case-card { position: relative; }

.case-card__link {
  display: block;
  group: hover;
}

.case-card__media {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3 / 2;
  background: var(--clr-surface);
  border-radius: var(--radius-md);
  margin-bottom: var(--sp-sm);
}

.case-card__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s var(--ease-out-expo);
}

.case-card__link:hover .case-card__media img {
  transform: scale(1.04);
}

.case-card__placeholder {
  width: 100%;
  height: 100%;
  background: var(--clr-surface);
}

.case-card__info {
  padding-block: var(--sp-xs);
}

.case-card__title {
  font-family: var(--font-sans);
  font-size: clamp(1rem, 1.5vw, 1.25rem);
  font-weight: 400;
  letter-spacing: -0.01em;
  margin-bottom: var(--sp-2xs);
}

.case-card__tagline {
  font-size: 0.875rem;
  color: var(--clr-muted);
  line-height: 1.4;
  margin-bottom: var(--sp-xs);
}

.case-card__meta {
  display: flex;
  align-items: center;
  gap: var(--sp-sm);
  font-size: 0.75rem;
  color: var(--clr-muted);
}

.case-card__services {
  display: flex;
  flex-wrap: wrap;
  gap: 0.25rem;
  list-style: none;
}

.case-card__services li::before {
  content: '·';
  margin-right: 0.25rem;
}
.case-card__services li:first-child::before {
  content: '';
  margin-right: 0;
}
</style>
