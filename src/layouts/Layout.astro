---
// Layout.astro — základní šablona pro všechny stránky
import AnimationInit from '../components/AnimationInit.astro'
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  ogImage?: string
}

const {
  title,
  description = 'Slant — Branding & UX Studio',
  ogImage,
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---
<!doctype html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />

  <title>{title} | Slant</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <meta property="og:title"       content={`${title} | Slant`} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:type"        content="website" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content="summary_large_image" />

  <!--
    FONTY — uprav dle svého brandingu.
    Aktuálně: DM Sans (sans) + DM Serif Display (display).
    Nebo použij Adobe Fonts přes Creative Cloud.
  -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;400;500&family=DM+Serif+Display:ital@0;1&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <!-- Navigace — uprav dle svého designu -->
  <header class="site-nav">
    <div class="container site-nav__inner">
      <a href="/" class="site-nav__logo" aria-label="Slant — home">Slant</a>
      <nav class="site-nav__links" aria-label="Hlavní navigace">
        <a href="/work">Work</a>
        <a href="/#contact">Contact</a>
      </nav>
    </div>
  </header>

  <main id="main-content">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container site-footer__inner">
      <span class="text-micro" style="color: var(--clr-muted)">
        © Slant {new Date().getFullYear()}
      </span>
      <span class="text-micro" style="color: var(--clr-muted)">
        Branding & UX Studio
      </span>
    </div>
  </footer>

  <!-- GSAP + Lenis init -->
  <AnimationInit />
</body>
</html>

<style>
/* ─── Navigace ──────────────────────────────────────────────────────────── */
.site-nav {
  position: fixed;
  inset: 0 0 auto;
  z-index: 100;
  padding-block: var(--sp-sm);
  border-bottom: 1px solid var(--clr-border);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  background: color-mix(in srgb, var(--clr-bg) 75%, transparent);
}

.site-nav__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.site-nav__logo {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 400;
  letter-spacing: -0.02em;
}

.site-nav__links {
  display: flex;
  gap: var(--sp-lg);
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.site-nav__links a {
  opacity: 0.5;
  transition: opacity 0.2s ease;
}

.site-nav__links a:hover { opacity: 1; }

/* ─── Main content — offset kvůli fixed nav ─────────────────────────────── */
main { padding-top: 4rem; }

/* ─── Footer ────────────────────────────────────────────────────────────── */
.site-footer {
  margin-top: var(--sp-3xl);
  padding-block: var(--sp-xl);
  border-top: 1px solid var(--clr-border);
}

.site-footer__inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
</style>
