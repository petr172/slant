---
// src/pages/work/index.astro — Work listing
import Layout from '../../layouts/Layout.astro'
import CaseStudyCard from '../../components/CaseStudyCard.astro'
import { client } from '../../lib/sanity'
import { ALL_CASE_STUDIES_QUERY } from '../../lib/queries'

const caseStudies = await client.fetch(ALL_CASE_STUDIES_QUERY)
---

<Layout
  title="Work"
  description="Vybrané projekty — branding, UX/UI, packaging a vizuální identity."
>
  <section class="work-listing container">

    <header class="work-listing__header" data-fade>
      <h1 class="text-display">Work</h1>
      <p class="work-listing__count text-micro" style="color: var(--clr-muted)">
        {caseStudies?.length ?? 0} projektů
      </p>
    </header>

    {caseStudies?.length > 0 ? (
      <div class="work-listing__grid">
        {caseStudies.map((cs: any) => (
          <CaseStudyCard
            title={cs.title}
            slug={cs.slug}
            tagline={cs.tagline}
            year={cs.year}
            services={cs.services}
            coverImage={cs.coverImage}
            featured={cs.featured}
          />
        ))}
      </div>
    ) : (
      <p class="work-listing__empty text-body" style="color: var(--clr-muted)">
        Zatím žádné projekty — přidej je v Sanity Studiu.
      </p>
    )}

  </section>
</Layout>

<style>
.work-listing {
  padding-block: var(--sp-2xl) var(--sp-3xl);
}

.work-listing__header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: var(--sp-2xl);
  padding-bottom: var(--sp-lg);
  border-bottom: 1px solid var(--clr-border);
}

.work-listing__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 28rem), 1fr));
  gap: var(--sp-2xl) var(--sp-lg);
}

.work-listing__empty {
  padding-top: var(--sp-xl);
}
</style>
