---
import WorkDetailPage from '../../../components/pages/WorkDetailPage.astro'
import { client } from '../../../lib/sanity'
import { ALL_SLUGS_QUERY, CASE_STUDY_BY_SLUG_QUERY } from '../../../lib/queries'

export async function getStaticPaths() {
  const slugs = await client.fetch<{ slug: string }[]>(ALL_SLUGS_QUERY)
  return slugs.filter(i => !!i.slug).map(i => ({ params: { slug: i.slug } }))
}

const { slug } = Astro.params
const cs = await client.fetch(CASE_STUDY_BY_SLUG_QUERY, { slug })
---
<WorkDetailPage lang="en" {slug} {cs} />
