# Zkopíruj tento soubor jako .env a doplň hodnoty
# Najdeš je na: https://sanity.io/manage → tvůj projekt

PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=production

# Google Analytics 4 — najdeš v GA4 → Admin → Data Streams → tvůj stream → Measurement ID
# Pokud prázdné, GA se nenačte (bezpečné pro dev prostředí)
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Kontaktní formulář — Resend + serverless (/api/contact) ──────────────────
# Server-only proměnné (BEZ prefixu PUBLIC_ → nikdy se nedostanou do klienta).
# Na Vercelu nastav v Project Settings → Environment Variables.

# Resend API klíč — https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Odesílatel — musí být na ověřené doméně v Resend (DNS records). Formát: "Jméno <adresa>"
RESEND_FROM=Slant <hello@slant.cz>

# Kam chodí interní notifikace o nových poptávkách
CONTACT_TO=hello@slant.cz

# Google Workspace Appointment Schedules — veřejný booking odkaz (Calendar → Appointment schedule → Share)
BOOKING_URL=https://calendar.app.google/your-booking-link
